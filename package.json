{
  "name": "@fdls/file-viewer",
  "version": "0.3.0",
  "private": false,
  "description": "React components for in-app file preview: shell (FileViewer), PDF viewer, and image pan/zoom. No Radix UI or icon library peer dependencies.",
  "license": "MIT",
  "author": "fidelesdev <matheusfideles2507@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fidelesdev/file-viewer.git"
  },
  "homepage": "https://github.com/fidelesdev/file-viewer#readme",
  "bugs": {
    "url": "https://github.com/fidelesdev/file-viewer/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/style.css"
  ],
  "keywords": [
    "react",
    "pdf",
    "viewer",
    "image",
    "preview",
    "file-preview",
    "react-pdf",
    "document-viewer"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "tsup && node scripts/bundle-lib-css.mjs && node scripts/prepend-style-import.mjs",
    "prepublishOnly": "npm run build:lib",
    "preview": "vite preview --outDir playground-dist"
  },
  "peerDependencies": {
    "pdfjs-dist": "~4.8.69",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-pdf": ">=9.0.0 <10.0.0",
    "react-to-print": "^3.0.0",
    "react-zoom-pan-pinch": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "pdfjs-dist": {
      "optional": false
    },
    "react-pdf": {
      "optional": false
    },
    "react-to-print": {
      "optional": false
    },
    "react-zoom-pan-pinch": {
      "optional": false
    }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "pdfjs-dist": "4.8.69",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-pdf": "~9.2.1",
    "react-to-print": "^3.1.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "tailwindcss": "^4.1.8",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.4.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
