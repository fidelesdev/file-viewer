{
  "name": "file-viewer",
  "version": "0.1.0",
  "private": false,
  "description": "React components for in-app file preview: dialog shell (ViewFile), PDF viewer, and image pan/zoom. Peer deps include Radix Dialog, Scroll Area, Tooltip, react-pdf, etc.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "keywords": [
    "react",
    "pdf",
    "viewer",
    "image",
    "preview",
    "radix-ui",
    "react-pdf"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "tsup",
    "prepublishOnly": "npm run build:lib",
    "preview": "vite preview --outDir playground-dist"
  },
  "peerDependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "lucide-react": "^0.400.0 || ^0.500.0 || ^0.600.0",
    "pdfjs-dist": "^4.8.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-pdf": "^9.0.0",
    "react-to-print": "^3.0.0",
    "react-zoom-pan-pinch": "^4.0.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "lucide-react": "^0.511.0",
    "pdfjs-dist": "4.8.69",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-pdf": "^9.2.1",
    "react-to-print": "^3.1.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "tailwindcss": "^4.1.8",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.4.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
